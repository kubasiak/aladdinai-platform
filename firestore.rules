rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Check if user owns this customer
    function isOwner(customerId) {
      return request.auth != null && request.auth.uid == customerId;
    }

    // Helper: Check if user is provider
    function isProvider() {
      return request.auth != null && request.auth.token.email == 'kubasiak.anna@gmail.com';
    }

    // Customer data: Public read, owner write
    match /customers/{customerId} {
      allow read: if true;  // Public can view landing pages
      allow write: if isOwner(customerId);  // Only owner can edit

      // Subcollections (videos, audio, screenshots)
      match /{subcollection}/{document} {
        allow read: if true;
        allow write: if isOwner(customerId);
      }
    }

    // Bandwidth tracking: Public read/write (for page view tracking and threshold checks)
    match /bandwidth-tracking/{customerId}/{document=**} {
      allow read: if true;  // Public can read bandwidth data for threshold checks
      allow write: if true;  // Anyone can track page views
    }

    // Platform settings: Public read for limits, provider write
    match /platform/{document} {
      allow read: if true;  // Public can read limits (for bandwidth checks)
      allow write: if isProvider();  // Provider only
    }
  }
}
