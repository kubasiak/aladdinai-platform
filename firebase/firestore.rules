rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(customerId) {
      return isAuthenticated() && request.auth.uid == customerId;
    }

    // Customer collection - root level
    match /customers/{customerId} {
      // PUBLIC READ: Anyone can read customer data (for public landing pages)
      // ADMIN WRITE: Only authenticated owner can write
      allow read: if true;  // Public can view
      allow write: if isOwner(customerId);  // Only admin can edit

      // Videos subcollection
      match /videos/{videoId} {
        allow read: if true;  // Public can view
        allow write: if isOwner(customerId);  // Only admin can edit
      }

      // Audio subcollection
      match /audio/{audioId} {
        allow read: if true;  // Public can view
        allow write: if isOwner(customerId);  // Only admin can edit
      }

      // Screenshots subcollection
      match /screenshots/{screenshotId} {
        allow read: if true;  // Public can view
        allow write: if isOwner(customerId);  // Only admin can edit
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
