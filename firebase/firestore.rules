rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(customerId) {
      return isAuthenticated() && request.auth.uid == customerId;
    }

    // Customer collection - root level
    match /customers/{customerId} {
      // Allow read/write only to the authenticated customer
      allow read, write: if isOwner(customerId);

      // Videos subcollection
      match /videos/{videoId} {
        allow read, write: if isOwner(customerId);
      }

      // Audio subcollection
      match /audio/{audioId} {
        allow read, write: if isOwner(customerId);
      }

      // Screenshots subcollection
      match /screenshots/{screenshotId} {
        allow read, write: if isOwner(customerId);
      }
    }

    // Public pages - anyone can read (for displaying landing pages)
    // But only authenticated users can read their own data
    match /public/{customerId} {
      allow read: if true;  // Public pages visible to all
      allow write: if isOwner(customerId);  // Only owner can update
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
