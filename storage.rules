rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Customer media files: Public read, owner can create/update/delete
    match /customers/{customerId}/{allPaths=**} {
      allow read: if true;  // Public can view
      allow create, update, delete: if request.auth != null && request.auth.uid == customerId;  // Owner can manage files
    }

    // Public static pages: Public read, authenticated users can write their own
    match /public-pages/{fileName} {
      allow read: if true;  // Anyone can view public pages
      allow write: if request.auth != null;  // Authenticated users can create/update their page
    }
  }
}
